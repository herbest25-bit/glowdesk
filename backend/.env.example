# ============================================================
# GlowDesk Backend — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ============================================================

# Servidor
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://seu-app.vercel.app

# ── Banco de dados (Supabase) ────────────────────────────────
# Copie de: Supabase → Settings → Database → Connection string → URI
# Use a connection pooling (porta 6543) em produção
DATABASE_URL=postgresql://postgres.[ref]:[senha]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ── Redis (Railway Redis Plugin) ────────────────────────────
# Gerado automaticamente pelo Railway ao adicionar o plugin Redis
REDIS_URL=redis://default:[senha]@[host].railway.app:[porta]

# ── Auth JWT ─────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_uma_chave_longa_e_aleatoria_em_producao

# ── Anthropic (Claude AI) ────────────────────────────────────
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp Business API (Meta) ─────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
